<launch>

  <arg name="stateEstimationTopic" default="/state_estimation"/>
  <arg name="registeredScanTopic" default="/registered_scan"/>
  <arg name="stateEstimationAtScanTopic" default="/state_estimation_at_scan"/>
  <arg name="sensorScanTopic" default="/sensor_scan"/>

  <node pkg="sensor_scan_generation" exec="sensorScanGeneration" name="sensorScanGeneration" output="screen">
    <param name="stateEstimationTopic" value="$(var stateEstimationTopic)" />
    <param name="registeredScanTopic" value="$(var registeredScanTopic)" />
    <param name="stateEstimationAtScanTopic" value="$(var stateEstimationAtScanTopic)" />
    <param name="sensorScanTopic" value="$(var sensorScanTopic)" />
  </node>

</launch>
